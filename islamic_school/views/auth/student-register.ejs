<%- include('../layout/header') %>

<style>
    :root {
        --primary: #1a5f3f;
        --secondary: #2d7a5f;
        --accent: #3db580;
        --light: #f8fdf9;
        --text: #1f2937;
        --border: #e5e7eb;
        --error: #dc2626;
        --success: #10b981;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    main {
        background: linear-gradient(135deg, var(--light) 0%, #e0f2e9 100%);
        min-height: calc(100vh - 140px);
        padding: 60px 20px;
    }

    .page-container {
        max-width: 900px;
        margin: 0 auto;
    }

    /* Header */
    .registration-header {
        text-align: center;
        margin-bottom: 50px;
    }

    .registration-header h1 {
        font-size: 42px;
        color: var(--primary);
        font-weight: 700;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
    }

    .registration-header p {
        font-size: 16px;
        color: #6b7280;
        margin-bottom: 4px;
    }

    .registration-header .subtitle {
        font-size: 14px;
        color: #9ca3af;
    }

    /* Progress Steps */
    .progress-steps {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 60px;
        padding: 30px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(26, 95, 63, 0.08);
    }

    .step {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        position: relative;
    }

    .step:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 30px;
        right: -10px;
        width: 20px;
        height: 2px;
        background: var(--border);
    }

    .step-circle {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin-bottom: 12px;
        font-weight: 700;
    }

    .step.inactive .step-circle {
        background: #e5e7eb;
        color: #9ca3af;
    }

    .step-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--primary);
    }

    .step.inactive .step-title {
        color: #9ca3af;
    }

    .step-description {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 4px;
    }

    /* Registration Card */
    .registration-card {
        background: white;
        border-radius: 16px;
        padding: 50px;
        box-shadow: 0 10px 40px rgba(26, 95, 63, 0.12);
        margin-bottom: 40px;
    }

    /* Alert Messages */
    .alert {
        padding: 16px;
        border-radius: 8px;
        margin-bottom: 24px;
        display: none;
        font-size: 14px;
        border-left: 4px solid;
        animation: slideIn 0.3s ease;
    }

    .alert.show {
        display: block;
    }

    .alert.error {
        background: #fef2f2;
        color: #991b1b;
        border-left-color: var(--error);
    }

    .alert.success {
        background: #f0fdf4;
        color: #15803d;
        border-left-color: var(--success);
    }

    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Form Sections */
    .form-section {
        margin-bottom: 40px;
        padding-bottom: 40px;
        border-bottom: 1px solid var(--border);
    }

    .form-section:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 25px;
    }

    .section-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .section-title {
        font-size: 20px;
        font-weight: 700;
        color: var(--primary);
    }

    .section-description {
        font-size: 13px;
        color: #6b7280;
        margin-left: 52px;
        margin-bottom: 20px;
    }

    /* Form Grid */
    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .form-grid.full {
        grid-template-columns: 1fr;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    /* Labels and Inputs */
    .form-group label {
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .required {
        color: var(--error);
        font-weight: 700;
    }

    .optional {
        color: #9ca3af;
        font-size: 12px;
        font-weight: 400;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
        padding: 12px 16px;
        border: 2px solid var(--border);
        border-radius: 8px;
        font-size: 14px;
        font-family: inherit;
        transition: all 0.3s ease;
        background: white;
    }

    .form-group input::placeholder,
    .form-group textarea::placeholder {
        color: #d1d5db;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(26, 95, 63, 0.1);
        background: #fafbff;
    }

    .form-group input.is-invalid,
    .form-group select.is-invalid {
        border-color: var(--error);
        background: #fef2f2;
    }

    .form-group input.is-valid,
    .form-group select.is-valid {
        border-color: var(--success);
        background: #f0fdf4;
    }

    .form-hint {
        font-size: 12px;
        color: #6b7280;
        margin-top: 6px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .form-error {
        font-size: 12px;
        color: var(--error);
        margin-top: 6px;
        display: none;
        animation: slideIn 0.3s ease;
    }

    .form-error.show {
        display: block;
    }

    /* Checkbox */
    .checkbox-group {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 16px;
        background: #f9fafb;
        border-radius: 8px;
        margin: 20px 0;
    }

    .checkbox-group input[type="checkbox"] {
        width: 20px;
        height: 20px;
        margin-top: 2px;
        cursor: pointer;
        accent-color: var(--primary);
        flex-shrink: 0;
    }

    .checkbox-group label {
        font-size: 14px;
        color: var(--text);
        cursor: pointer;
        line-height: 1.6;
        margin: 0;
    }

    .checkbox-group a {
        color: var(--primary);
        font-weight: 600;
        text-decoration: none;
    }

    .checkbox-group a:hover {
        text-decoration: underline;
    }

    /* Buttons */
    .button-group {
        display: flex;
        gap: 12px;
        margin-top: 40px;
    }

    .btn {
        padding: 14px 32px;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        width: 100%;
        box-shadow: 0 6px 20px rgba(26, 95, 63, 0.25);
    }

    .btn-primary:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(26, 95, 63, 0.35);
    }

    .btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    /* Footer Link */
    .footer-link {
        text-align: center;
        margin-top: 24px;
        padding-top: 24px;
        border-top: 1px solid var(--border);
        font-size: 14px;
        color: #6b7280;
    }

    .footer-link a {
        color: var(--primary);
        font-weight: 600;
        text-decoration: none;
    }

    .footer-link a:hover {
        text-decoration: underline;
    }

    /* Success Message */
    .success-message {
        display: none;
        text-align: center;
        padding: 60px 40px;
    }

    .success-message.show {
        display: block;
    }

    .success-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, var(--success), #059669);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        margin: 0 auto 24px;
        animation: scaleIn 0.5s ease;
    }

    @keyframes scaleIn {
        from {
            transform: scale(0);
        }
        to {
            transform: scale(1);
        }
    }

    .success-message h2 {
        font-size: 32px;
        color: var(--primary);
        margin-bottom: 12px;
        font-weight: 700;
    }

    .success-message p {
        font-size: 16px;
        color: #6b7280;
        margin-bottom: 12px;
    }

    .success-number {
        font-size: 18px;
        color: var(--primary);
        font-weight: 700;
        background: #f0fdf4;
        padding: 12px 20px;
        border-radius: 8px;
        display: inline-block;
        margin-top: 16px;
    }

    /* Responsive */
    @media (max-width: 768px) {
        main {
            padding: 40px 20px;
        }

        .registration-header h1 {
            font-size: 28px;
        }

        .progress-steps {
            grid-template-columns: 1fr;
            gap: 12px;
            padding: 20px;
            margin-bottom: 40px;
        }

        .step {
            flex-direction: row;
            justify-content: flex-start;
            text-align: left;
        }

        .step:not(:last-child)::after {
            display: none;
        }

        .step-circle {
            width: 50px;
            height: 50px;
            font-size: 20px;
            flex-shrink: 0;
        }

        .step-text {
            flex: 1;
        }

        .registration-card {
            padding: 30px;
        }

        .form-grid {
            grid-template-columns: 1fr;
            gap: 15px;
        }

        .button-group {
            flex-direction: column;
        }

        .btn {
            width: 100%;
        }
    }

    @media (max-width: 480px) {
        main {
            padding: 30px 16px;
        }

        .registration-header h1 {
            font-size: 24px;
        }

        .registration-card {
            padding: 20px;
            border-radius: 12px;
        }

        .section-header {
            margin-bottom: 16px;
        }

        .section-icon {
            width: 36px;
            height: 36px;
            font-size: 18px;
        }

        .section-title {
            font-size: 18px;
        }

        .section-description {
            margin-left: 44px;
            margin-bottom: 16px;
            font-size: 12px;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            padding: 11px 14px;
            font-size: 16px;
        }

        .btn {
            padding: 12px 20px;
            font-size: 14px;
        }
    }
</style>

<main>
    <div class="page-container">
        <!-- Header -->
        <div class="registration-header">
            <h1>
                <i class="fas fa-user-graduate"></i>
                Student Registration
            </h1>
            <p>Join Islamic School Community</p>
            <div class="subtitle">Complete all fields marked with <span class="required">*</span> to create your account</div>
        </div>

        <!-- Progress Steps -->
        <div class="progress-steps">
            <div class="step">
                <div class="step-circle">1</div>
                <div class="step-title">Personal Info</div>
                <div class="step-description">Your details</div>
            </div>
            <div class="step">
                <div class="step-circle">2</div>
                <div class="step-title">Guardian Info</div>
                <div class="step-description">Parent details</div>
            </div>
            <div class="step">
                <div class="step-circle">3</div>
                <div class="step-title">Account Setup</div>
                <div class="step-description">Login credentials</div>
            </div>
        </div>

        <!-- Success Message (hidden by default) -->
        <div class="registration-card success-message" id="successMessage">
            <div class="success-icon">
                <i class="fas fa-check"></i>
            </div>
            <h2>Registration Successful! 🎉</h2>
            <p>Welcome to Islamic School. Your account has been created successfully.</p>
            <p>Your Admission Number:</p>
            <div class="success-number" id="admissionNumber">Loading...</div>
            <p style="margin-top: 24px; font-size: 14px;">
                You can now <a href="/auth/student-login" style="color: var(--primary); font-weight: 600;">login with your credentials</a>
            </p>
        </div>

        <!-- Registration Form -->
        <div class="registration-card" id="formCard">
            <!-- Alert Messages -->
            <div class="alert error <%= error_msg && error_msg.length ? 'show' : '' %>" id="errorAlert">
                <%= error_msg && error_msg.length ? error_msg[0] : '' %>
            </div>
            <div class="alert success <%= success_msg && success_msg.length ? 'show' : '' %>" id="successAlert">
                <%= success_msg && success_msg.length ? success_msg[0] : '' %>
            </div>

            <form id="registrationForm" method="POST" action="/auth/student-register" novalidate>
                <!-- SECTION 1: Personal Information -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-icon">
                            <i class="fas fa-user"></i>
                        </div>
                        <div>
                            <div class="section-title">Personal Information</div>
                        </div>
                    </div>
                    <div class="section-description">Tell us about yourself</div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>
                                First Name <span class="required">*</span>
                            </label>
                            <input type="text" id="first_name" name="first_name" placeholder="e.g., Ahmed" autocomplete="given-name" required>
                            <div class="form-hint"><i class="fas fa-info-circle"></i> Your first/given name</div>
                            <div class="form-error" id="error_first_name"></div>
                        </div>
                        <div class="form-group">
                            <label>
                                Last Name <span class="required">*</span>
                            </label>
                            <input type="text" id="last_name" name="last_name" placeholder="e.g., Hassan" autocomplete="family-name" required>
                            <div class="form-hint"><i class="fas fa-info-circle"></i> Your family name</div>
                            <div class="form-error" id="error_last_name"></div>
                        </div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>
                                Email Address <span class="required">*</span>
                            </label>
                            <input type="email" id="email" name="email" placeholder="your.email@example.com" required>
                            <div class="form-hint"><i class="fas fa-info-circle"></i> We'll use this to contact you</div>
                            <div class="form-error" id="error_email"></div>
                        </div>
                        <div class="form-group">
                            <label>
                                Date of Birth <span class="required">*</span>
                            </label>
                            <input type="date" id="date_of_birth" name="date_of_birth" required>
                            <div class="form-hint"><i class="fas fa-info-circle"></i> Must be age appropriate</div>
                            <div class="form-error" id="error_date_of_birth"></div>
                        </div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>
                                Gender <span class="required">*</span>
                            </label>
                            <select id="gender" name="gender" required>
                                <option value="">-- Select your gender --</option>
                                <option value="male">Male</option>
                                <option value="female">Female</option>
                            </select>
                            <div class="form-error" id="error_gender"></div>
                        </div>
                        <div class="form-group">
                            <label>
                                Enrollment Class <span class="required">*</span>
                            </label>
                            <select id="class_name" name="class_name" required>
                                <option value="">-- Select your class --</option>
                                <option value="PRELIMINARY 2">PRELIMINARY 2</option>
                                <option value="PRELIMINARY 3">PRELIMINARY 3</option>
                                <option value="CLASS 1">CLASS 1</option>
                                <option value="CLASS 2">CLASS 2</option>
                                <option value="CLASS 3">CLASS 3</option>
                                <option value="CLASS 4">CLASS 4</option>
                                <option value="CLASS 5">CLASS 5</option>
                                <option value="ALIF CLASS">ALIF CLASS</option>
                                <option value="BA CLASS">BA CLASS</option>
                                <option value="TA CLASS">TA CLASS</option>
                            </select>
                            <div class="form-error" id="error_class_name"></div>
                        </div>
                    </div>
                </div>

                <!-- SECTION 2: Guardian Information -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-icon">
                            <i class="fas fa-users"></i>
                        </div>
                        <div>
                            <div class="section-title">Guardian Information</div>
                        </div>
                    </div>
                    <div class="section-description">Tell us about your parent/guardian</div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>
                                Guardian Name <span class="required">*</span>
                            </label>
                            <input type="text" id="parent_name" name="parent_name" placeholder="Parent or guardian full name" required>
                            <div class="form-hint"><i class="fas fa-info-circle"></i> Full name of your parent/guardian</div>
                            <div class="form-error" id="error_parent_name"></div>
                        </div>
                        <div class="form-group">
                            <label>
                                Guardian Phone <span class="required">*</span>
                            </label>
                            <input type="tel" id="parent_phone" name="parent_phone" placeholder="+234 123 456 7890" required>
                            <div class="form-hint"><i class="fas fa-info-circle"></i> Contact number for emergency</div>
                            <div class="form-error" id="error_parent_phone"></div>
                        </div>
                    </div>

                    <div class="form-grid full">
                        <div class="form-group">
                            <label>
                                Guardian Email <span class="optional">(Optional)</span>
                            </label>
                            <input type="email" id="parent_email" name="parent_email" placeholder="parent@example.com">
                            <div class="form-hint"><i class="fas fa-info-circle"></i> Alternative contact method</div>
                            <div class="form-error" id="error_parent_email"></div>
                        </div>
                    </div>

                    <div class="form-grid full">
                        <div class="form-group">
                            <label>
                                Residential Address <span class="optional">(Optional)</span>
                            </label>
                            <textarea id="address" name="address" placeholder="Your full residential address" rows="3"></textarea>
                            <div class="form-hint"><i class="fas fa-info-circle"></i> Where we can reach you by mail</div>
                            <div class="form-error" id="error_address"></div>
                        </div>
                    </div>
                </div>

                <!-- SECTION 3: Account Setup -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-icon">
                            <i class="fas fa-lock"></i>
                        </div>
                        <div>
                            <div class="section-title">Account Setup</div>
                        </div>
                    </div>
                    <div class="section-description">Create your login credentials</div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>
                                Password <span class="required">*</span>
                            </label>
                            <input type="password" id="password" name="password" placeholder="At least 6 characters" minlength="6" required>
                            <div class="form-hint"><i class="fas fa-info-circle"></i> Strong password recommended</div>
                            <div class="form-error" id="error_password"></div>
                        </div>
                        <div class="form-group">
                            <label>
                                Confirm Password <span class="required">*</span>
                            </label>
                            <input type="password" id="confirm_password" name="confirm_password" placeholder="Enter password again" minlength="6" required>
                            <div class="form-hint"><i class="fas fa-info-circle"></i> Must match password above</div>
                            <div class="form-error" id="error_confirm_password"></div>
                        </div>
                    </div>
                </div>

                <!-- Terms Agreement -->
                <div class="checkbox-group">
                    <input type="checkbox" id="agree" name="agree" required>
                    <label for="agree">
                        I confirm that all information provided is accurate and true. I agree to the school's <a href="#">terms of service</a> and <a href="#">code of conduct</a>.
                    </label>
                </div>

                <!-- Submit Button -->
                <div class="button-group">
                    <button type="submit" class="btn btn-primary" id="submitBtn">
                        <i class="fas fa-check-circle"></i>
                        <span id="submitText">Complete Registration</span>
                    </button>
                </div>

                <!-- Login Link -->
                <div class="footer-link">
                    Already have an account? <a href="/auth/student-login">Login here</a>
                </div>
            </form>
        </div>
    </div>
</main>

<script>
    const form = document.getElementById('registrationForm');
    const errorAlert = document.getElementById('errorAlert');
    const successAlert = document.getElementById('successAlert');
    const submitBtn = document.getElementById('submitBtn');
    const submitText = document.getElementById('submitText');

    // Simple validation for required fields
    function validateForm() {
        const requiredFields = [
            'first_name', 'last_name', 'email', 'date_of_birth', 'gender', 'class_name',
            'parent_name', 'parent_phone', 'password', 'confirm_password'
        ];

        let isValid = true;
        let firstError = null;

        // Clear all previous errors
        requiredFields.forEach(fieldName => {
            const errorEl = document.getElementById(`error_${fieldName}`);
            const field = document.getElementById(fieldName);
            if (errorEl) errorEl.classList.remove('show');
            if (field) field.classList.remove('is-invalid');
        });

        // Check each field
        requiredFields.forEach(fieldName => {
            const field = document.getElementById(fieldName);
            if (!field) return;

            const value = field.value.trim();
            const errorEl = document.getElementById(`error_${fieldName}`);

            if (!value) {
                isValid = false;
                field.classList.add('is-invalid');
                if (errorEl) {
                    errorEl.textContent = `${fieldName.replace(/_/g, ' ').charAt(0).toUpperCase() + fieldName.replace(/_/g, ' ').slice(1)} is required`;
                    errorEl.classList.add('show');
                    if (!firstError) firstError = fieldName;
                }
            }
        });

        // Check email format
        const emailField = document.getElementById('email');
        const emailValue = emailField.value.trim();
        const emailError = document.getElementById('error_email');
        if (emailValue && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailValue)) {
            isValid = false;
            emailField.classList.add('is-invalid');
            if (emailError) {
                emailError.textContent = 'Please enter a valid email';
                emailError.classList.add('show');
                if (!firstError) firstError = 'email';
            }
        }

        // Check password match
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirm_password').value;
        if (password && confirmPassword && password !== confirmPassword) {
            isValid = false;
            const confirmField = document.getElementById('confirm_password');
            confirmField.classList.add('is-invalid');
            const confirmError = document.getElementById('error_confirm_password');
            if (confirmError) {
                confirmError.textContent = 'Passwords do not match';
                confirmError.classList.add('show');
                if (!firstError) firstError = 'confirm_password';
            }
        }

        // Check password length
        if (password && password.length < 6) {
            isValid = false;
            const passwordField = document.getElementById('password');
            passwordField.classList.add('is-invalid');
            const passwordError = document.getElementById('error_password');
            if (passwordError) {
                passwordError.textContent = 'Password must be at least 6 characters';
                passwordError.classList.add('show');
                if (!firstError) firstError = 'password';
            }
        }

        // Check terms agreement
        const agreeField = document.getElementById('agree');
        if (!agreeField.checked) {
            isValid = false;
            if (!firstError) firstError = 'agree';
        }

        // Scroll to first error
        if (firstError && firstError !== 'agree') {
            const errorField = document.getElementById(firstError);
            if (errorField) {
                errorField.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }

        return isValid;
    }

    // Add real-time validation - clear error when user starts typing
    ['first_name', 'last_name', 'email', 'date_of_birth', 'gender', 'class_name',
     'parent_name', 'parent_phone', 'password', 'confirm_password'].forEach(fieldName => {
        const field = document.getElementById(fieldName);
        if (field) {
            field.addEventListener('input', () => {
                const errorEl = document.getElementById(`error_${fieldName}`);
                if (field.classList.contains('is-invalid') && field.value.trim()) {
                    field.classList.remove('is-invalid');
                    if (errorEl) errorEl.classList.remove('show');
                }
            });
            field.addEventListener('change', () => {
                const errorEl = document.getElementById(`error_${fieldName}`);
                if (field.classList.contains('is-invalid') && field.value.trim()) {
                    field.classList.remove('is-invalid');
                    if (errorEl) errorEl.classList.remove('show');
                }
            });
        }
    });

    // Form submission
    form.addEventListener('submit', (e) => {
        e.preventDefault();

        // Hide alerts first
        errorAlert.classList.remove('show');
        successAlert.classList.remove('show');
        errorAlert.textContent = '';
        successAlert.textContent = '';

        // Validate
        if (!validateForm()) {
            errorAlert.textContent = 'Please fix the errors above';
            errorAlert.classList.add('show');
            return;
        }

        const agreeField = document.getElementById('agree');
        if (agreeField && !agreeField.checked) {
            errorAlert.textContent = 'Please agree to the terms before submitting';
            errorAlert.classList.add('show');
            agreeField.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
        }

        // Submit button state
        submitBtn.disabled = true;
        submitText.textContent = 'Processing...';
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> <span id="submitText">Processing...</span>';

        // Submit form
        setTimeout(() => {
            form.submit();
        }, 300);
    });
</script>

