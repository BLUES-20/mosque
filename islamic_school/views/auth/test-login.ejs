<!DOCTYPE html>
<html>

<head>
    <title>Test Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h4>Test Student Login</h4>
                    </div>
                    <div class="card-body">
                        <form action="/auth/student-login" method="POST">
                            <div class="mb-3">
                                <label>Admission Number</label>
                                <input type="text" name="admission_number" class="form-control" value="STU2026001" required>
                            </div>
                            <div class="mb-3">
                                <label>Password</label>
                                <input type="password" name="password" class="form-control" value="student123" required>
                            </div>
                            <button type="submit" class="btn btn-success w-100">LOGIN</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
