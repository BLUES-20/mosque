<%- include('../layout/header') %>

<style>
    .login-section {
        background: linear-gradient(135deg, #f8fdf9 0%, #e8f5ed 50%, #d4edde 100%);
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 1rem;
    }

    .login-box {
        background: white;
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(26, 95, 63, 0.15);
        overflow: hidden;
        width: 100%;
        max-width: 480px;
        animation: slideUp 0.6s ease-out;
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .login-header {
        background: linear-gradient(135deg, #1a5f3f, #2d7a5f);
        color: white;
        padding: 45px 35px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .login-header::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
        animation: pulse-bg 4s ease-in-out infinite;
    }

    @keyframes pulse-bg {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }

    .login-header h2 {
        position: relative;
        z-index: 1;
        font-weight: 700;
        margin-bottom: 5px;
    }

    .login-header p {
        position: relative;
        z-index: 1;
        opacity: 0.9;
    }

    .login-header .icon-wrapper {
        position: relative;
        z-index: 1;
        width: 80px;
        height: 80px;
        background: rgba(255,255,255,0.15);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        backdrop-filter: blur(10px);
    }

    .login-body {
        padding: 40px 35px;
    }

    .login-body .form-control {
        border-radius: 12px;
        padding: 14px 18px;
        border: 2px solid #e5e7eb;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: #f9fafb;
    }

    .login-body .form-control:focus {
        border-color: #1a5f3f;
        box-shadow: 0 0 0 4px rgba(26, 95, 63, 0.1);
        background: white;
        transform: translateY(-1px);
    }

    .login-body .input-group-text {
        border-radius: 12px 0 0 12px;
        border: 2px solid #e5e7eb;
        border-right: none;
        background: #f9fafb;
        color: #1a5f3f;
        transition: all 0.3s ease;
    }

    .login-body .input-group .form-control {
        border-radius: 0 12px 12px 0;
        border-left: none;
    }

    .login-body .input-group:focus-within .input-group-text {
        border-color: #1a5f3f;
        background: white;
    }

    .btn-login-submit {
        background: linear-gradient(135deg, #1a5f3f, #2d7a5f);
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 600;
        font-size: 1.05rem;
        width: 100%;
        color: white;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(26, 95, 63, 0.3);
    }

    .btn-login-submit::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.5s;
    }

    .btn-login-submit:hover::before {
        left: 100%;
    }

    .btn-login-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(26, 95, 63, 0.4);
        color: white;
    }

    .login-footer-links {
        text-align: center;
        padding-top: 1.5rem;
        border-top: 1px solid #e5e7eb;
        margin-top: 1.5rem;
    }

    .login-footer-links a {
        color: #1a5f3f;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .login-footer-links a:hover {
        color: #2d7a5f;
        text-decoration: underline;
    }

    .recaptcha-wrapper {
        display: flex;
        justify-content: center;
        margin-bottom: 1rem;
    }

    /* Flash messages inside login box */
    .login-flash .alert {
        border-radius: 12px;
        margin-bottom: 1.5rem;
        font-size: 0.95rem;
    }
</style>

<section class="login-section">
    <div class="login-box">
        <div class="login-header">
            <div class="icon-wrapper">
                <i class="fas fa-school fa-2x"></i>
            </div>
            <h2>Student Portal</h2>
            <p class="mb-0">Islamic School Management</p>
        </div>
        <div class="login-body">
            <!-- Flash messages -->
            <div class="login-flash">
                <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i><%= success_msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                <% } %>
                <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i><%= error_msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                <% } %>
            </div>

            <form action="/auth/student-login" method="POST" id="studentLoginForm">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Admission Number</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                        <input type="text" name="admission_number" class="form-control" placeholder="STU2025001" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        <input type="password" name="password" class="form-control" placeholder="Enter password" required>
                    </div>
                </div>
                <div class="mb-3 d-flex justify-content-between align-items-center">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="remember">
                        <label class="form-check-label" for="remember">Remember me</label>
                    </div>
                    <a href="/auth/forgot-password" class="text-decoration-none" style="color: #1a5f3f; font-size: 0.9rem;">Forgot password?</a>
                </div>

                <!-- Google reCAPTCHA -->
                <% if (recaptcha_site_key) { %>
                <div class="recaptcha-wrapper mb-3">
                    <div class="g-recaptcha" data-sitekey="<%= recaptcha_site_key %>"></div>
                </div>
                <% } %>

                <button type="submit" class="btn btn-login-submit" id="studentLoginSubmitBtn">
                    <i class="fas fa-sign-in-alt me-2"></i><span id="studentLoginSubmitText">LOGIN</span>
                </button>
            </form>

            <div class="login-footer-links">
                <p class="mb-2">New student? <a href="/auth/student-register">Register here</a></p>
                <p class="mb-0"><a href="/auth/staff-login"><i class="fas fa-user-tie me-1"></i>Staff Login</a></p>
            </div>
        </div>
    </div>
</section>

<!-- reCAPTCHA Script -->
<% if (recaptcha_site_key) { %>
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
<% } %>

<script>
    const studentLoginForm = document.getElementById('studentLoginForm');
    const studentLoginSubmitBtn = document.getElementById('studentLoginSubmitBtn');
    const studentLoginSubmitText = document.getElementById('studentLoginSubmitText');

    if (studentLoginForm && studentLoginSubmitBtn && studentLoginSubmitText) {
        studentLoginForm.addEventListener('submit', () => {
            studentLoginSubmitBtn.disabled = true;
            studentLoginSubmitText.textContent = 'Signing in...';
            studentLoginSubmitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i><span id="studentLoginSubmitText">Signing in...</span>';
        });
    }
</script>

<%- include('../layout/footer') %>
