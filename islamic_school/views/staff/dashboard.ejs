<%- include('../layout/header') %>

<style>
    :root {
        --islamic-primary: #1a5f3f;
        --islamic-secondary: #2d7a5f;
        --accent-color: #ffc107;
        --glass-bg: rgba(255, 255, 255, 0.9);
        --glass-border: rgba(255, 255, 255, 0.2);
    }

    body {
        background-color: #f4f7f6;
        font-family: 'Outfit', sans-serif;
    }

    .dashboard-header {
        background: linear-gradient(135deg, var(--islamic-primary), var(--islamic-secondary));
        color: white;
        padding: 4rem 0 6rem 0;
        border-radius: 0 0 3rem 3rem;
        margin-bottom: -4rem;
        position: relative;
        overflow: hidden;
    }

    .dashboard-header::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 400px;
        height: 400px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 50%;
        z-index: 0;
    }

    .welcome-text {
        position: relative;
        z-index: 1;
    }

    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border);
        border-radius: 1.5rem;
        box-shadow: 0 10px 35px rgba(0, 0, 0, 0.05);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 2.5rem 1.5rem;
        text-decoration: none;
        color: inherit;
    }

    .glass-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 45px rgba(26, 95, 63, 0.15);
        background: white;
        color: inherit;
    }

    .icon-wrapper {
        width: 80px;
        height: 80px;
        border-radius: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        transition: all 0.3s ease;
        position: relative;
    }

    .bg-soft-primary {
        background-color: #e7f0ff;
        color: #0d6efd;
    }

    .bg-soft-success {
        background-color: #e8f5e9;
        color: #1b5e20;
    }

    .bg-soft-info {
        background-color: #e0f7fa;
        color: #00838f;
    }

    .bg-soft-warning {
        background-color: #fff8e1;
        color: #ff8f00;
    }

    .bg-soft-danger {
        background-color: #ffebee;
        color: #c62828;
    }

    .glass-card:hover .icon-wrapper {
        transform: scale(1.1);
    }

    .card-title {
        font-weight: 700;
        margin-bottom: 0.5rem;
        font-size: 1.25rem;
    }

    .card-desc {
        color: #777;
        font-size: 0.9rem;
        text-align: center;
    }

    .notification-dot {
        position: absolute;
        top: -5px;
        right: -5px;
        width: 20px;
        height: 20px;
        background-color: #dc3545;
        color: white;
        border-radius: 50%;
        font-size: 0.7rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        border: 2px solid white;
    }

    .quick-stat {
        background: rgba(255, 255, 255, 0.1);
        padding: 0.8rem 1.5rem;
        border-radius: 1rem;
        backdrop-filter: blur(5px);
        display: inline-flex;
        align-items: center;
        margin-right: 1rem;
        margin-top: 1rem;
    }

    .quick-stat i {
        margin-right: 0.8rem;
        font-size: 1.2rem;
    }

</style>

<div class="dashboard-header">
    <div class="container welcome-text">
        <div class="row align-items-center">
            <div class="col-md-8 text-md-start text-center">
                <span class="badge bg-warning text-dark mb-2 px-3 py-2 rounded-pill fw-bold">STAFF PORTAL</span>
                <h1 class="display-4 fw-bold mb-1">Assalamu Alaikum, <%= staff.name %>!</h1>
                <p class="lead opacity-75 mb-0">Manage your students, academics, and communications efficiently.</p>

                <div class="d-flex flex-wrap justify-content-center justify-content-md-start">
                    <div class="quick-stat">
                        <i class="fas fa-users"></i>
                        <div>
                            <div class="small opacity-75">Students</div>
                            <div class="fw-bold"><%= studentCount %></div>
                        </div>
                    </div>
                    <% if (unreadMessagesCount > 0) { %>
                    <div class="quick-stat">
                        <i class="fas fa-envelope-open-text"></i>
                        <div>
                            <div class="small opacity-75">Inbound Inquiries</div>
                            <div class="fw-bold"><%= unreadMessagesCount %> New</div>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
            <div class="col-md-4 d-none d-md-block text-end">
                <i class="fas fa-mosque fa-8x opacity-25"></i>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5" style="margin-top: 2rem;">
    <div class="row g-4 position-relative" style="z-index: 2;">
        <!-- Manage Students -->
        <div class="col-md-4">
            <a href="/staff/manage-students" class="glass-card">
                <div class="icon-wrapper bg-soft-primary">
                    <i class="fas fa-user-graduate fa-2x"></i>
                </div>
                <h5 class="card-title">Manage Students</h5>
                <p class="card-desc">Advanced portal to view, edit and track student registrations.</p>
            </a>
        </div>

        <!-- Academic Results -->
        <div class="col-md-4">
            <a href="/staff/upload-result" class="glass-card">
                <div class="icon-wrapper bg-soft-success">
                    <i class="fas fa-file-invoice fa-2x"></i>
                </div>
                <h5 class="card-title">Upload Results</h5>
                <p class="card-desc">Input examinee scores and generate academic performance reports.</p>
            </a>
        </div>

        <!-- View Results History -->
        <div class="col-md-4">
            <a href="/staff/view-results" class="glass-card">
                <div class="icon-wrapper bg-soft-info">
                    <i class="fas fa-chart-pie fa-2x"></i>
                </div>
                <h5 class="card-title">Verify Results</h5>
                <p class="card-desc">Search and analyze past terms and academic session records.</p>
            </a>
        </div>

        <!-- Contact Messages -->
        <div class="col-md-4">
            <a href="/staff/contact-messages" class="glass-card">
                <div class="icon-wrapper bg-soft-warning">
                    <i class="fas fa-comments fa-2x"></i>
                    <% if (unreadMessagesCount > 0) { %>
                    <div class="notification-dot"><%= unreadMessagesCount %></div>
                    <% } %>
                </div>
                <h5 class="card-title">Inquiries</h5>
                <p class="card-desc">Respond to visitor messages and manage public communications.</p>
            </a>
        </div>

        <!-- Announcements -->
        <div class="col-md-4">
            <a href="/staff/announcements" class="glass-card">
                <div class="icon-wrapper bg-soft-danger">
                    <i class="fas fa-bullhorn fa-2x"></i>
                </div>
                <h5 class="card-title">Announcements</h5>
                <p class="card-desc">Broadcast important school updates and notices to everyone.</p>
            </a>
        </div>

        <!-- School Settings / Documents -->
        <div class="col-md-4">
            <a href="/staff/upload-document" class="glass-card">
                <div class="icon-wrapper bg-soft-primary">
                    <i class="fas fa-folder-open fa-2x"></i>
                </div>
                <h5 class="card-title">Document Center</h5>
                <p class="card-desc">Upload course materials, schedules and school policy documents.</p>
            </a>
        </div>
    </div>
</div>

<%- include('../layout/footer') %>
