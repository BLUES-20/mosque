<%- include('../layout/header') %>

<style>
    .admin-register-container {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        min-height: 100vh;
        padding: 2rem 0;
    }
    .register-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        padding: 3rem;
        max-width: 600px;
        margin: 0 auto;
    }
    .header-section {
        text-align: center;
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 3px solid #1a5f3f;
    }
    .header-section h1 {
        color: #1a5f3f;
        font-weight: 700;
        font-size: 2.2rem;
        margin-bottom: 0.5rem;
    }
    .header-section p {
        color: #666;
        font-size: 1.1rem;
    }
    .form-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 0.5rem;
        display: block;
    }
    .form-control, .form-select, textarea {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 0.9rem 1.2rem;
        font-size: 1rem;
        transition: all 0.3s;
    }
    .form-control:focus, .form-select:focus {
        border-color: #1a5f3f;
        box-shadow: 0 0 0 0.2rem rgba(26,95,63,0.15);
    }
    .form-file {
        border: 2px dashed #dee2e6;
        border-radius: 12px;
        padding: 2.5rem;
        text-align: center;
        background: #f8f9fa;
        transition: all 0.3s;
    }
    .form-file:hover {
        border-color: #1a5f3f;
        background: #f0f7f4;
    }
    .form-row-dual {
        display: flex;
        gap: 1rem;
    }
    .form-row-dual .form-control {
        flex: 1;
    }
    .btn-primary {
        background: linear-gradient(135deg, #1a5f3f 0%, #2d7a5f 100%);
        border: none;
        padding: 1rem 3rem;
        font-weight: 600;
        border-radius: 12px;
        font-size: 1.1rem;
        transition: all 0.3s;
    }
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(26,95,63,0.3);
    }
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #1a5f3f;
        font-weight: 500;
        text-decoration: none;
        margin-bottom: 1.5rem;
    }
    .back-link:hover {
        color: #134b30;
    }
    .alert {
        border-radius: 12px;
        border: none;
    }
    @media (max-width: 768px) {
        .form-row-dual { flex-direction: column; gap: 0; }
        .register-card { margin: 1rem; padding: 2rem 1.5rem; }
    }
</style>

<div class="admin-register-container">
    <div class="container">
        <% if (success_msg && success_msg.length) { %>
            <div class="alert alert-success d-flex align-items-center">
                <i class="fas fa-check-circle me-3"></i>
                <%= success_msg[0] %>
            </div>
        <% } %>
        <% if (error_msg && error_msg.length) { %>
            <div class="alert alert-danger d-flex align-items-center">
                <i class="fas fa-exclamation-triangle me-3"></i>
                <%= error_msg[0] %>
            </div>
        <% } %>

        <div class="register-card">
            <a href="/staff/manage-students" class="back-link">
                <i class="fas fa-arrow-left"></i> Back to Students
            </a>

            <div class="header-section">
                <i class="fas fa-user-plus fa-3x mb-3 text-success"></i>
                <h1>Register New Student</h1>
                <p>Admin quick registration - no payment required</p>
            </div>

            <form method="POST" action="/staff/register-student" enctype="multipart/form-data">
                <div class="form-row-dual mb-4">
                    <div>
                        <label class="form-label">First Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="first_name" required maxlength="50">
                    </div>
                    <div>
                        <label class="form-label">Last Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="last_name" required maxlength="50">
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Email <span class="text-danger">*</span></label>
                    <input type="email" class="form-control" name="email" required>
                </div>

                <div class="form-row-dual mb-4">
                    <div>
                        <label class="form-label">Class</label>
                        <select class="form-select" name="class_name">
                            <option value="">Select Class</option>
                            <option value="JSS1">JSS 1</option>
                            <option value="JSS2">JSS 2</option>
                            <option value="JSS3">JSS 3</option>
                            <option value="SSS1">SSS 1</option>
                            <option value="SSS2">SSS 2</option>
                            <option value="SSS3">SSS 3</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Password <span class="text-danger">*</span></label>
                        <input type="password" class="form-control" name="password" required minlength="6">
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">Date of Birth</label>
                        <input type="date" class="form-control" name="date_of_birth">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Gender</label>
                        <select class="form-select" name="gender">
                            <option value="">Select</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">Parent Name</label>
                        <input type="text" class="form-control" name="parent_name" maxlength="100">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Parent Phone</label>
                        <input type="tel" class="form-control" name="parent_phone">
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Address</label>
                    <textarea class="form-control" name="address" rows="3" maxlength="255"></textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label">Profile Picture (optional)</label>
                    <div class="form-file">
                        <input type="file" class="form-control" name="profile_picture" accept="image/jpeg,image/png">
                        <small class="text-muted d-block mt-2">JPG/PNG, max 2MB - uploads to Cloudinary</small>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-user-plus me-2"></i>Create Student Account
                </button>
            </form>
        </div>
    </div>
</div>

<%- include('../layout/footer') %>
