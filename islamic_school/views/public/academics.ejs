<%- include('../layout/header') %>

<style>
    :root {
        --primary: #1a5f3f;
        --secondary: #2d7a5f;
        --accent: #3db580;
        --light: #f8fdf9;
        --text: #1f2937;
        --border: #e5e7eb;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* Header */
    .breadcrumb-section {
        background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
        color: white;
        padding: 60px 20px;
        text-align: center;
    }

    .breadcrumb-section h1 {
        font-size: 42px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    /* Content Sections */
    .section {
        padding: 100px 20px;
    }

    .section-header {
        text-align: center;
        margin-bottom: 60px;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }

    .section-header h2 {
        font-size: 42px;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 16px;
    }

    .section-header p {
        font-size: 16px;
        color: #6b7280;
    }

    /* Programs Grid */
    .programs-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .program-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(26, 95, 63, 0.08);
        transition: all 0.3s ease;
    }

    .program-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(26, 95, 63, 0.15);
    }

    .program-header {
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        padding: 40px;
        text-align: center;
    }

    .program-header i {
        font-size: 48px;
        margin-bottom: 16px;
        display: block;
    }

    .program-header h3 {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .program-level {
        font-size: 14px;
        opacity: 0.9;
    }

    .program-body {
        padding: 30px;
    }

    .subject-list {
        list-style: none;
    }

    .subject-list li {
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
        color: #6b7280;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .subject-list li:last-child {
        border-bottom: none;
    }

    .subject-list i {
        color: var(--accent);
        font-weight: 700;
    }

    /* Features Section */
    .features-white {
        background: white;
    }

    .features-bg {
        background: var(--light);
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 30px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .feature-item {
        background: white;
        border-radius: 12px;
        padding: 40px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(26, 95, 63, 0.08);
        transition: all 0.3s ease;
    }

    .feature-item:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(26, 95, 63, 0.15);
    }

    .features-bg .feature-item {
        box-shadow: none;
        border: 2px solid var(--border);
    }

    .features-bg .feature-item:hover {
        border-color: var(--primary);
        box-shadow: 0 10px 30px rgba(26, 95, 63, 0.1);
    }

    .feature-icon {
        font-size: 48px;
        color: var(--primary);
        margin-bottom: 16px;
    }

    .feature-item h3 {
        font-size: 20px;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 12px;
    }

    .feature-item p {
        color: #6b7280;
        font-size: 14px;
        line-height: 1.7;
    }

    @media (max-width: 768px) {
        .breadcrumb-section h1 {
            font-size: 32px;
        }

        .section-header h2 {
            font-size: 32px;
        }

        .section {
            padding: 60px 20px;
        }
    }
</style>

<!-- Header -->
<section class="breadcrumb-section">
    <div class="container">
